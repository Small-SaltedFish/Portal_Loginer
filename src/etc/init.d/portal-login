#!/bin/sh /etc/rc.common
# /etc/init.d/portal-login

USE_PROCD=1
START=95   # 网络(20) uhttpd(80) 之后，确保 WAN 先起来
STOP=10

PROG="/usr/bin/portal-login"

start_service() {
    local enabled
    enabled=$(uci -q get portal_login.main.enabled 2>/dev/null)
    [ "$enabled" = "0" ] && { logger -t portal-login "已禁用，跳过启动"; return 0; }

    procd_open_instance
    procd_set_param command "$PROG" daemon
    # 崩溃后 30s 重启，0=永不放弃
    procd_set_param respawn 30 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/portal-login.pid
    # UCI 配置变更时自动 reload
    procd_add_reload_trigger "portal_login"
    procd_close_instance
}

stop_service() {
    rm -f /var/lock/portal-login.lock
}

reload_service() {
    stop
    start
}
